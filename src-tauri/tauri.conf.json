{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexusky",
  "version": "0.3.7",
  "identifier": "com.nexusky.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:renderer",
    "devUrl": "http://127.0.0.1:5188",
    "beforeBuildCommand": "pnpm run build:renderer",
    "frontendDist": "../out/renderer-tauri"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Nexusky",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 12 },
        "backgroundColor": "#1e1e1e",
        "shadow": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
