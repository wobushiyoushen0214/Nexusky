{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "jsx": "react-jsx",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "paths": {
            "@shared/*": [
                "packages/shared/src/*"
            ],
            "@renderer/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "env.d.ts"
    ]
}