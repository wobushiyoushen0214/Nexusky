{
    "name": "nexusky",
    "version": "0.8.2",
    "private": true,
    "description": "Local-first Markdown vault workbench",
    "author": "Nexusky",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wobushiyoushen0214/Nexusky.git"
    },
    "bugs": {
        "url": "https://github.com/wobushiyoushen0214/Nexusky/issues"
    },
    "homepage": "https://github.com/wobushiyoushen0214/Nexusky#readme",
    "main": "./out/main/index.js",
    "packageManager": "pnpm@10.30.3",
    "engines": {
        "node": ">=22 <23",
        "pnpm": ">=10 <11"
    },
    "scripts": {
        "dev": "node scripts/dev.mjs",
        "build": "electron-vite build",
        "rebuild": "node scripts/rebuild-native.mjs",
        "rebuild:app-deps": "electron-builder install-app-deps",
        "postinstall": "node scripts/rebuild-native.mjs",
        "preview": "electron-vite preview",
        "pack": "electron-vite build && electron-builder --dir",
        "dist": "electron-vite build && electron-builder",
        "dist:win": "electron-vite build && electron-builder --win",
        "cli": "node scripts/nexusky-cli.mjs",
        "fixture:large-vault": "node scripts/create-large-vault-fixture.mjs",
        "fixture:sync-disaster-recovery": "node scripts/create-sync-disaster-recovery-fixture.mjs",
        "typecheck": "tsc -p packages/shared/tsconfig.json --noEmit && tsc -p packages/main/tsconfig.json --noEmit && tsc -p packages/renderer/tsconfig.json --noEmit",
        "lint": "eslint . --ext .ts,.tsx",
        "test": "node scripts/vitest-electron.mjs run",
        "test:watch": "node scripts/vitest-electron.mjs"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.95.1",
        "@supabase/supabase-js": "^2.105.4",
        "@tiptap/core": "^2.27.2",
        "@tiptap/extension-code-block-lowlight": "^3.23.1",
        "@tiptap/extension-highlight": "^2.27.2",
        "@tiptap/extension-mathematics": "^3.23.1",
        "@tiptap/extension-placeholder": "^2.10.0",
        "@tiptap/extension-table": "^2.27.2",
        "@tiptap/extension-table-cell": "^2.27.2",
        "@tiptap/extension-table-header": "^2.27.2",
        "@tiptap/extension-table-row": "^2.27.2",
        "@tiptap/extension-task-item": "^2.27.2",
        "@tiptap/extension-task-list": "^2.27.2",
        "@tiptap/pm": "^2.10.0",
        "@tiptap/react": "^2.10.0",
        "@tiptap/starter-kit": "^2.10.0",
        "better-sqlite3": "^12.9.0",
        "chokidar": "^3.6.0",
        "d3-drag": "^3.0.0",
        "d3-force": "^3.0.0",
        "d3-selection": "^3.0.0",
        "d3-zoom": "^3.0.0",
        "diff": "^9.0.0",
        "dompurify": "^3.4.2",
        "electron-updater": "^6.8.3",
        "gray-matter": "^4.0.3",
        "i18next": "^26.2.0",
        "katex": "^0.16.45",
        "lowlight": "^3.3.0",
        "marked": "^18.0.3",
        "mermaid": "^11.14.0",
        "openai": "^6.37.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-i18next": "^17.0.8",
        "tiptap-markdown": "^0.8.10",
        "ws": "^8.20.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/d3-drag": "^3.0.7",
        "@types/d3-force": "^3.0.10",
        "@types/d3-selection": "^3.0.11",
        "@types/d3-zoom": "^3.0.8",
        "@types/diff": "^8.0.0",
        "@types/dompurify": "^3.2.0",
        "@types/node": "^22.10.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^4.3.0",
        "electron": "^39.8.10",
        "electron-builder": "^25.1.8",
        "electron-vite": "^2.3.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.0",
        "vite": "^6.0.0",
        "vitest": "^3.2.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "esbuild",
            "better-sqlite3"
        ]
    }
}
